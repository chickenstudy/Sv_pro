# =============================================================================
# SV-PRO (Savant-Vision Professional) .gitignore
# =============================================================================

# 1. Python specific
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/

# 2. AI Models & Large Binaries (Don't track model weights in Git)
# Skip large zip, onnx, pt, and hardware-specific engines
models/*.zip
models/*.onnx
models/*.engine
models/**/*.zip
models/**/*.onnx
models/**/*.engine
models/**/*.pt
models/**/*.bin
models/**/*.weights

# 3. Data & Storage (Auto-generated during runtime)
data/
Detect/
reports/
db_data/
redis_data/
mqtt_data/
mqtt_log/
logs/
*.log

# 4. Savant & DeepStream (ZMQ sockets and IPC)
*.ipc
*.sock

# 5. Environment & Secrets
.env
.env.*
!.env.example
secrets/

# 6. IDEs & Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db


node_modules/
__pycache__/
